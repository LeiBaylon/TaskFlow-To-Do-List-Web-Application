rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Personal user data ───────────────────────────────

    // Profile, preferences, stats — owner only
    match /users/{uid}/meta/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Personal tasks — owner only
    match /users/{uid}/tasks/{taskId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Personal folders — owner only
    match /users/{uid}/folders/{folderId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Workspace references (denormalized index under each user)
    // Owner can read + write. Workspace members can also write
    // because updateWorkspace / deleteWorkspace / removeWorkspaceMember
    // update other members' refs in a batch.
    match /users/{uid}/workspaces/{wsId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
                   && (request.auth.uid == uid
                       || exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)));
    }

    // ─── Workspaces ───────────────────────────────────────
    match /workspaces/{wsId} {
      function isMember() {
        return request.auth != null
            && exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid));
      }

      // Workspace root document
      // • read / create — any authenticated user
      //   (read needed when accepting an invitation; create for new workspace)
      // • update — members can change anything;
      //   non-members may only increment memberCount by 1 (invitation acceptance batch)
      // • delete — members only
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if isMember();
      allow update: if isMember()
                    || (request.auth != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
                        && request.resource.data.memberCount == resource.data.memberCount + 1);

      // Members subcollection
      match /members/{memberId} {
        allow read, update, delete: if isMember();
        // create: user creates own member doc (accepting invitation)
        //         OR existing member creates for another user
        allow create: if request.auth != null
                   && (request.auth.uid == memberId || isMember());
      }

      // Tasks subcollection — members only
      match /tasks/{taskId} {
        allow read, write: if isMember();
      }

      // Folders subcollection
      match /folders/{folderId} {
        allow read, update, delete: if isMember();
        // create: members can create folders normally;
        // during workspace bootstrap the inbox folder is created in the same batch
        // before the workspace doc exists, so we also allow create when the
        // workspace document does not yet exist (pre-commit state).
        allow create: if isMember()
                   || (request.auth != null
                       && !exists(/databases/$(database)/documents/workspaces/$(wsId)));
      }

      // Activity log — members only
      match /activity/{entryId} {
        allow read, write: if isMember();
      }

      // Chat messages — members only
      match /messages/{msgId} {
        allow read, write: if isMember();
      }

      // DM channels — only participants who are workspace members
      match /dms/{channelId} {
        allow read: if isMember()
          && request.auth.uid in resource.data.participants;
        allow create: if isMember()
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants.size() == 2;

        // DM messages within a channel
        match /messages/{msgId} {
          allow read: if isMember()
            && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(wsId)/dms/$(channelId)).data.participants;
          allow create: if isMember()
            && request.auth.uid == request.resource.data.senderId
            && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(wsId)/dms/$(channelId)).data.participants;
        }
      }
    }

    // ─── Registered emails (invite lookup) ────────────────
    match /registeredEmails/{emailId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Invitations ──────────────────────────────────────
    match /invitations/{invId} {
      function invitedUserMatches() {
        return request.auth != null
            && request.auth.token.email != null
            && request.auth.token.email.lower() == resource.data.invitedEmail;
      }

      // Any authenticated user can create invitations
      allow create: if request.auth != null;
      // Only the invited user can read / accept / decline
      allow read, update: if invitedUserMatches();
    }
  }
}
